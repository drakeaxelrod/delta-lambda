if SHIELD_DELTA_LAMBDA_LEFT

config ZMK_KEYBOARD_NAME
    default "Lambda"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif

if SHIELD_DELTA_LAMBDA_RIGHT

config ZMK_KEYBOARD_NAME
    default "Lambda Right"

endif

if SHIELD_DELTA_LAMBDA_LEFT || SHIELD_DELTA_LAMBDA_RIGHT

config ZMK_SPLIT
    default y

endif
